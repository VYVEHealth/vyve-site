      <div>
        <div class="nav__logo" style="margin-bottom:14px">
          <div class="nav__logo-mark"><svg viewBox="0 0 32 32" width="18" height="18" fill="none"><path d="M6 8 L16 22 L26 8" stroke="white" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
          <span class="footer__logo-name">VYVE<span> Health</span></span>
        </div>
        <p class="footer__tagline">Building health before it breaks. Proactive wellbeing for people and the organisations they work for.</p>
      </div>
      <div><p class="footer__col-title">For Employers</p><ul class="footer__links">
          <li><a href="employers.html">Why VYVE</a></li>
          <li><a href="corp-pricing.html">Pricing</a></li>
